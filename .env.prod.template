# .env.prod.template - 本番環境用環境変数テンプレート
# このファイルを .env.prod にコピーし、実際の値を設定してください
# 【重要】.env.prod ファイル自体は Git にコミットしないでください

# 使用方法:
#   cp .env.prod.template .env.prod
#   # 各値を編集
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d

# --- General ---
NODE_ENV=production

# --- OpenRouter API ---
# LLM との通信および埋め込みベクトル生成（python-service）に使用する API キー
# https://openrouter.ai/ で取得
OPENROUTER_API_KEY=your_openrouter_api_key_here

# --- システム設定の暗号化キー ---
# DBにAPIキーを保存・読み込みするすべての環境で必須（保存時だけでなく読み込み時も必要）
# AES-256-GCMで使用する32バイト（256ビット）のBase64エンコードキー
# openssl rand -base64 32 で生成すること
SYSTEM_CONFIG_ENCRYPTION_KEY=generate_with_openssl_rand_base64_32

# --- JWT 設定 ---
# openssl rand -hex 32 で生成した強固なシークレットを設定すること
JWT_SECRET=generate_with_openssl_rand_hex_32
JWT_EXPIRES_IN=1d

# --- フロントエンド API URL ---
# 本番ドメインを設定（Caddy が同一ドメインでルーティングするため同一 URL）
IDEA_FRONTEND_API_BASE_URL=https://YOUR_DOMAIN_HERE
ADMIN_API_BASE_URL=https://YOUR_DOMAIN_HERE

# --- CORS 設定 ---
# Caddy が SSL 終端するため https:// を使用すること
IDEA_CORS_ORIGIN=https://YOUR_DOMAIN_HERE,https://www.YOUR_DOMAIN_HERE

# --- MongoDB 認証 ---
# 強固なパスワードを設定すること（例: openssl rand -base64 32）
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=generate_strong_password_here

# OPENAI_API_KEY は不要になりました。OPENROUTER_API_KEY が python-service の埋め込み生成でも使用されます。

# --- テーマ削除機能 ---
# 本番環境では通常 false に設定する
ALLOW_DELETE_THEME=false

# --- 管理者パスワードハッシュ化用ペッパー ---
# AdminUser.js のパスワードハッシュ化に使用する（必須）
# openssl rand -hex 32 で生成してください
# 注意: 設定しないと管理者ログインが失敗します
PASSWORD_PEPPER=generate_with_openssl_rand_hex_32

# --- Python サービス URL ---
# embeddingService.js が参照する python-service の URL
# Docker Compose 環境ではデフォルト値が使用されるため通常変更不要
PYTHON_SERVICE_URL=http://python-service:8000

# --- ドメイン設定 ---
DOMAIN=YOUR_DOMAIN_HERE

# --- Cloudflare API トークン（Caddy TLS 証明書取得用）---
# Cloudflare ダッシュボードで以下の権限を持つトークンを作成:
#   - Zone:Zone:Read（Zone ID 解決に必須）
#   - Zone:DNS:Edit（DNS-01 チャレンジ用 TXT レコード操作に必須）
# https://dash.cloudflare.com/profile/api-tokens
CF_API_TOKEN=your_cloudflare_api_token_here
